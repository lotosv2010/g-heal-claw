# ================================================================
# g-heal-claw 环境变量模板
# 所有变量由 packages/shared/env.ts 的 Zod Schema 校验
# 复制为 .env.local 或 .env 后填写
# ================================================================

# -------- 基础设施 --------
POSTGRES_USER=ghealclaw
POSTGRES_PASSWORD=ghealclaw
POSTGRES_DB=ghealclaw
DATABASE_URL=postgresql://ghealclaw:ghealclaw@localhost:5432/ghealclaw

REDIS_URL=redis://localhost:6379

# -------- MinIO / S3 对象存储（可选，Sourcemap 功能需要，未配置时自动跳过）--------
# MINIO_ROOT_USER=minioadmin
# MINIO_ROOT_PASSWORD=minioadmin
# MINIO_ENDPOINT=http://localhost:9000
# MINIO_REGION=us-east-1
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET_SOURCEMAPS=sourcemaps
# MINIO_BUCKET_EVENTS=events-archive
# MINIO_BUCKET_HEAL=heal-artifacts

# -------- 应用运行时 --------
NODE_ENV=development
SERVER_PORT=3001
WEB_PORT=3000
AI_AGENT_PORT=3002
PUBLIC_API_BASE_URL=http://localhost:3001
PUBLIC_WEB_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# -------- 鉴权 --------
JWT_SECRET=please-change-me-to-32-byte-random
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_SECRET=please-change-me-to-32-byte-random
REFRESH_TOKEN_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# -------- 限流与采样 --------
GATEWAY_RATE_LIMIT_PER_SEC=100
GATEWAY_RATE_LIMIT_BURST=200
SERVER_DEFAULT_SAMPLE_RATE=1.0

# -------- Error Processor（ADR-0026）--------
# sync | queue | dual；灰度回滚期可临时设 dual 做双写比对，稳态 queue
ERROR_PROCESSOR_MODE=queue
ERROR_PROCESSOR_CONCURRENCY=4
ERROR_PROCESSOR_ATTEMPTS=3
ERROR_PROCESSOR_BACKOFF_MS=2000

# -------- 分区维护 cron（events_raw 周分区预建 N+2 水位，空串禁用）--------
PARTITION_MAINTENANCE_CRON=0 3 * * 1

# -------- 邮件（告警通知）--------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=alerts@ghealclaw.local
SMTP_SECURE=false

# -------- IP 地域库 --------
GEOIP_DB_PATH=./data/GeoLite2-City.mmdb

# -------- AI Agent --------
# LLM Provider 选择：deepseek | deepseek-reasoner | gemini | moonshot | minimax | ollama
LLM_PROVIDER=deepseek

# Deepseek
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_REASONER_MODEL=deepseek-reasoner

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Moonshot (Kimi)
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_API_KEY=
MOONSHOT_MODEL=moonshot-v1-128k

# MiniMax
MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-M1

# Ollama (本地)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# 护栏
AI_MAX_STEPS=20
AI_MAX_PATCH_LOC=100

# -------- Git 平台集成（自愈 PR）--------
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_WEBHOOK_SECRET=
GITLAB_PERSONAL_ACCESS_TOKEN=
GITLAB_HOST=https://gitlab.com

# -------- 沙箱 --------
HEAL_SANDBOX_IMAGE=node:20-alpine
HEAL_SANDBOX_TIMEOUT_MS=600000
HEAL_SANDBOX_MEMORY_MB=2048

# -------- 通知渠道（可选默认值）--------
DINGTALK_DEFAULT_WEBHOOK=
WECHAT_WORK_DEFAULT_WEBHOOK=
SLACK_DEFAULT_WEBHOOK=
SMS_PROVIDER=none
SMS_ACCESS_KEY=
SMS_ACCESS_SECRET=
SMS_SIGN_NAME=

# -------- 实时监控 SSE（ADR-0030）--------
REALTIME_SAMPLE_RATE=1.0
REALTIME_STREAM_MAXLEN=1000
REALTIME_MAX_CONN_PER_PROJECT=10

# -------- Sourcemap LRU（ADR-0031）--------
SOURCEMAP_LRU_CAPACITY=100

# -------- 可观测 --------
# LOG_TARGET: stdout(默认,Docker/K8s) | file(裸机,写本地文件) | cloud(云日志) | all(全部)
LOG_TARGET=stdout
LOG_LEVEL=info
# LOG_DIR: 仅 LOG_TARGET=file|all 时生效，日志文件目录
LOG_DIR=./logs
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=g-heal-claw-server
PROMETHEUS_ENABLED=true
