{
  "name": "@g-heal-claw/server",
  "version": "0.0.1",
  "private": true,
  "description": "g-heal-claw backend — NestJS + Fastify modular monolith (ingest gateway, processor, dashboard API, sourcemap store, notification).",
  "author": {
    "name": "Robin",
    "url": "https://github.com/lotosv2010"
  },
  "license": "MIT",
  "homepage": "https://github.com/lotosv2010/g-heal-claw/tree/main/apps/server#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lotosv2010/g-heal-claw.git",
    "directory": "apps/server"
  },
  "bugs": {
    "url": "https://github.com/lotosv2010/g-heal-claw/issues"
  },
  "keywords": [
    "g-heal-claw",
    "nestjs",
    "fastify",
    "drizzle",
    "postgresql",
    "bullmq",
    "monitoring",
    "observability",
    "ingest-gateway",
    "typescript"
  ],
  "type": "module",
  "main": "dist/main.js",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "nest build",
    "clean": "rimraf dist .turbo",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "lint": "eslint src --ext .ts",
    "test": "vitest run && vitest run --config vitest.e2e.config.ts",
    "test:unit": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1041.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "@g-heal-claw/shared": "workspace:*",
    "@nestjs/bullmq": "^10.2.3",
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-fastify": "^11.1.19",
    "@nestjs/schedule": "^4.1.2",
    "@nestjs/swagger": "^11.4.1",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.76.4",
    "dotenv-flow": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "lru-cache": "^10.4.3",
    "nanoid": "^5.0.9",
    "postgres": "^3.4.9",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "source-map": "^0.7.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.19",
    "@swc/core": "^1.9.3",
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "drizzle-kit": "^0.30.1",
    "rimraf": "^6.0.1",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.2",
    "typescript": "~6.0.3",
    "unplugin-swc": "^1.5.1",
    "vitest": "^4.1.5"
  }
}
