{
  "name": "@g-heal-claw/server",
  "version": "0.0.1",
  "private": true,
  "description": "g-heal-claw 后端（NestJS + Fastify，模块化单体）",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "clean": "rimraf dist .turbo",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "lint": "eslint src --ext .ts",
    "test": "vitest run && vitest run --config vitest.e2e.config.ts",
    "test:unit": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.1.3",
    "@g-heal-claw/shared": "workspace:*",
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-fastify": "^11.1.19",
    "@nestjs/swagger": "^11.4.1",
    "dotenv-flow": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "postgres": "^3.4.9",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.19",
    "@swc/core": "^1.9.3",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "rimraf": "^6.0.1",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.2",
    "typescript": "~6.0.3",
    "unplugin-swc": "^1.5.1",
    "vitest": "^4.1.5"
  }
}
