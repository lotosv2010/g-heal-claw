# apps/web 本地变量模板。复制为 .env.local 后填写。
# 真实校验由 packages/shared 的 Env Schema 负责（Phase 1.1.7 接入认证时引入）

# 后端 API 基地址。Dashboard 页面通过该地址请求 `/dashboard/v1/performance/overview`
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# 默认项目 ID（ADR-0015）。T1.1.7 接入项目切换器后，由 Topbar 下拉覆盖
NEXT_PUBLIC_DEFAULT_PROJECT_ID=demo
