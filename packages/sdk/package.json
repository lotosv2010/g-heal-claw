{
  "name": "@g-heal-claw/sdk",
  "version": "0.0.1",
  "description": "Browser SDK for g-heal-claw — capture web vitals, JS errors, resource failures, and API performance in zero-config fashion (<10KB gzip).",
  "private": true,
  "author": {
    "name": "Robin",
    "url": "https://github.com/lotosv2010"
  },
  "license": "MIT",
  "homepage": "https://github.com/lotosv2010/g-heal-claw/tree/main/packages/sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lotosv2010/g-heal-claw.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/lotosv2010/g-heal-claw/issues"
  },
  "keywords": [
    "frontend-monitoring",
    "web-vitals",
    "error-tracking",
    "api-monitoring",
    "rum",
    "apm",
    "browser-sdk",
    "performance",
    "sentry-alternative",
    "observability",
    "typescript",
    "lcp",
    "cls",
    "inp",
    "tbt"
  ],
  "type": "module",
  "main": "./dist/sdk.umd.cjs",
  "module": "./dist/sdk.esm.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/sdk.umd.cjs",
  "jsdelivr": "./dist/sdk.umd.cjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/sdk.esm.js",
      "require": "./dist/sdk.umd.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "!src/**/*.test.ts",
    "!src/**/*.spec.ts"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "vite build",
    "clean": "rimraf dist .turbo",
    "dev": "vite build --watch",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@g-heal-claw/shared": "workspace:*",
    "web-vitals": "^4.2.4"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "jsdom": "^29.1.0",
    "rimraf": "^6.0.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.5"
  }
}
