{
  "name": "@g-heal-claw/shared",
  "version": "0.0.1",
  "private": true,
  "description": "Shared contracts for g-heal-claw — Zod event schemas, BullMQ queue name constants, and environment validation used by SDK, server, and ai-agent.",
  "author": {
    "name": "Robin",
    "url": "https://github.com/lotosv2010"
  },
  "license": "MIT",
  "homepage": "https://github.com/lotosv2010/g-heal-claw/tree/main/packages/shared#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lotosv2010/g-heal-claw.git",
    "directory": "packages/shared"
  },
  "bugs": {
    "url": "https://github.com/lotosv2010/g-heal-claw/issues"
  },
  "keywords": [
    "g-heal-claw",
    "shared",
    "contracts",
    "zod",
    "schema",
    "monitoring",
    "typescript"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./events": {
      "types": "./dist/events/index.d.ts",
      "import": "./dist/events/index.js"
    },
    "./env": {
      "types": "./dist/env/index.d.ts",
      "import": "./dist/env/index.js"
    },
    "./queues": {
      "types": "./dist/queues/index.d.ts",
      "import": "./dist/queues/index.js"
    },
    "./id": {
      "types": "./dist/id.d.ts",
      "import": "./dist/id.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc --build",
    "clean": "rimraf dist .turbo",
    "dev": "tsc --build --watch",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "nanoid": "^5.0.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
